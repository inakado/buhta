vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

classes: {
  role: {
    style.fill: "#EFF6FF"
    style.stroke: "#2563EB"
    style.stroke-width: 2
    style.border-radius: 10
  }
  admin: {
    style.fill: "#F8FAFC"
    style.stroke: "#64748B"
    style.stroke-width: 2
    style.border-radius: 10
  }
  product: {
    style.fill: "#F5F3FF"
    style.stroke: "#7C3AED"
    style.stroke-width: 2
    style.border-radius: 10
  }
  result: {
    style.fill: "#ECFDF5"
    style.stroke: "#16A34A"
    style.stroke-width: 2
    style.border-radius: 10
  }
  production: {
    style.fill: "#FFFBEB"
    style.stroke: "#D97706"
    style.stroke-width: 2
    style.border-radius: 10
  }
  distributor: {
    style.fill: "#ECFEFF"
    style.stroke: "#0891B2"
    style.stroke-width: 2
    style.border-radius: 10
  }
  courier: {
    style.fill: "#F0FDF4"
    style.stroke: "#16A34A"
    style.stroke-width: 2
    style.border-radius: 10
  }
  sales: {
    style.fill: "#FDF2F8"
    style.stroke: "#DB2777"
    style.stroke-width: 2
    style.border-radius: 10
  }
  money: {
    style.fill: "#FEF2F2"
    style.stroke: "#DC2626"
    style.stroke-width: 2
    style.border-radius: 10
  }
  notify: {
    style.fill: "#EEF2FF"
    style.stroke: "#4F46E5"
    style.stroke-width: 2
    style.border-radius: 10
  }
}

roles: {
  label: "Роли"
  direction: right
  style.fill: "#FFFFFF"
  style.stroke: "#CBD5E1"

  director: {
    label: "Директор\nШаблоны продукции\nСтатистика\nСписание денег\nНикита — пользователь\nс этой ролью"
    class: role
  }

  commercial: {
    label: "Коммерческий руководитель\nОстатки распределителя\nПродажи\nУведомления производству"
    class: role
  }

  production_manager: {
    label: "Заведующий производством\nСырье и тара\nВыпуск продукции\nПеремещение на распределитель"
    class: role
  }

  distributor_worker: {
    label: "Работник распределителя\nБаланс распределителя\nКлиенты\nПродажи"
    class: role
  }

  courier: {
    label: "Курьер\nЗагрузка продукции\nПродажи\nСгрузка продукции и наличных"
    class: role
  }

  admin: {
    label: "Администратор системы\nПользователи\nРоли\nСправочники"
    class: admin
  }
}

main_flow: {
  label: "Основной бизнес-процесс"
  direction: down
  style.fill: "#FFFFFF"
  style.stroke: "#CBD5E1"

  templates: {
    label: "1. Шаблоны продукции\nРоль: директор\nИсточник автозаполнения\nдля будущих выпусков"
    class: product
  }

  raw_and_packaging: {
    label: "2. Сырье и тара\nРоль: заведующий производством\nФиксирует поступление\nсырья и тары"
    class: production
  }

  release: {
    label: "3. Выпуск продукции\nРоль: заведующий производством\nКопирует цену и поля\nшаблона в партию"
    class: production
  }

  stock: {
    label: "Результат: готовая продукция\nОстаток готовой продукции\nпоявляется на производстве"
    class: result
  }

  move_to_distributor: {
    label: "4. Перемещение на распределитель\nРоль: заведующий производством\nПередает готовую продукцию\nна распределитель"
    class: production
  }

  distributor_balance: {
    label: "Распределитель\nТоварный остаток\nНаличный денежный баланс\nВ v1 один, позже может быть больше"
    class: distributor
  }

  notification: {
    label: "Уведомление производству\nРоль: коммерческий руководитель\nСвободная задача\nСтатус: новое / выполнено"
    class: notify
  }

  client: {
    label: "Клиент\nСоздается или выбирается\nперед продажей\nТелефон уникален"
    class: sales
  }

  distributor_sale: {
    label: "Продажа с распределителя\nРоль: работник распределителя\nили коммерческий руководитель\nСпособ оплаты: наличные / безнал"
    class: sales
  }

  courier_load: {
    label: "Загрузка курьера\nРоль: курьер\nБерет продукцию\nс распределителя на свой баланс"
    class: courier
  }

  courier_balance: {
    label: "Баланс курьера\nПродукция у курьера\nНаличные от продаж"
    class: courier
  }

  courier_sale: {
    label: "Продажа курьером\nРоль: курьер\nКлиент создается или выбирается\nкак при продаже с распределителя"
    class: sales
  }

  courier_unload: {
    label: "Сгрузка курьера\nРоль: курьер\nОдной операцией возвращает\nостаток продукции и наличные\nна распределитель"
    class: courier
  }

  distributor_cash_sale: {
    label: "Наличная продажа\nс распределителя\nНаличный баланс\nраспределителя увеличивается"
    class: money
  }

  courier_cash_sale: {
    label: "Наличная продажа\nкурьером\nНаличный баланс курьера\nувеличивается"
    class: money
  }

  money_cashless: {
    label: "Безналичная продажа\nНаличный баланс не меняется\nДеньги уходят сразу на ИП"
    class: money
  }

  revenue_stats: {
    label: "Статистика выручки\nОбщая / наличная / безналичная\nБез разрезов в v1"
    class: result
  }

  action_log: {
    label: "История действий\nВсе операции пишутся\nИсправления только\nновой операцией"
    class: admin
  }

  money_writeoff: {
    label: "Списание денег\nРоль: директор\nНикита — пользователь\nс ролью директор"
    class: money
  }

  raw_and_packaging -> release
  templates -> release
  release -> stock
  stock -> move_to_distributor
  move_to_distributor -> distributor_balance
  notification -> release {
    style.stroke: "#4F46E5"
    style.stroke-dash: 4
  }
  distributor_balance -> client
  client -> distributor_sale
  distributor_balance -> courier_load
  courier_load -> courier_balance
  courier_balance -> client
  client -> courier_sale
  courier_balance -> courier_unload
  courier_unload -> distributor_balance
  distributor_sale -> distributor_cash_sale
  distributor_sale -> money_cashless
  courier_sale -> courier_cash_sale
  courier_sale -> money_cashless
  distributor_sale -> revenue_stats
  courier_sale -> revenue_stats
  distributor_cash_sale -> distributor_balance {
    style.stroke: "#DC2626"
  }
  courier_cash_sale -> courier_balance {
    style.stroke: "#DC2626"
  }
  distributor_balance -> money_writeoff {
    style.stroke: "#DC2626"
  }
  distributor_sale -> action_log {
    style.stroke: "#64748B"
    style.stroke-dash: 4
  }
  courier_sale -> action_log {
    style.stroke: "#64748B"
    style.stroke-dash: 4
  }
  courier_unload -> action_log {
    style.stroke: "#64748B"
    style.stroke-dash: 4
  }
}

control: {
  label: "Контроль и системные функции"
  direction: right
  style.fill: "#FFFFFF"
  style.stroke: "#CBD5E1"

  director_stats: {
    label: "Директор\nВидит статистику,\nостатки и деньги\nСписывает денежные средства"
    class: role
  }

  commercial_control: {
    label: "Коммерческий руководитель\nВидит распределитель,\nпродажи, остатки\nи денежные показатели"
    class: role
  }

  production_visibility: {
    label: "Заведующий производством\nВидит остатки\nна распределителе\nи уведомления"
    class: production
  }

  admin_functions: {
    label: "Администратор системы\nСупер-права\nПользователи, роли,\nсправочники"
    class: admin
  }
}

roles -> main_flow {
  style.opacity: 0
}
main_flow -> control {
  style.opacity: 0
}

legend: {
  label: "Цветовая маркировка"
  direction: right
  style.fill: "#FFFFFF"
  style.stroke: "#CBD5E1"

  template: {
    label: "Шаблоны продукции"
    class: product
  }

  production: {
    label: "Производство"
    class: production
  }

  distributor: {
    label: "Распределитель"
    class: distributor
  }

  courier: {
    label: "Курьер"
    class: courier
  }

  sales: {
    label: "Продажи и клиенты"
    class: sales
  }

  money: {
    label: "Деньги"
    class: money
  }

  notify: {
    label: "Уведомления"
    class: notify
  }

  admin: {
    label: "Администрирование"
    class: admin
  }
}

control -> legend {
  style.opacity: 0
}
