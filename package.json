{
	"name": "buhta",
	"private": true,
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"dev": "turbo dev",
		"dev:infra": "docker compose up -d postgres",
		"dev:api": "pnpm --filter @buhta/api dev",
		"dev:web": "pnpm --filter @buhta/web dev",
		"build": "turbo build",
		"doctor": "react-doctor",
		"doctor:local": "react-doctor --no-telemetry --yes --blocking none",
		"lint": "turbo lint",
		"lint:boundaries": "eslint \"apps/*/{app,src,test}/**/*.{ts,tsx}\" \"packages/*/src/**/*.{ts,tsx}\" --no-error-on-unmatched-pattern --quiet",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"test:ci": "pnpm --filter @buhta/shared test && pnpm --filter @buhta/web test && pnpm --filter @buhta/api test:ci",
		"smoke": "node scripts/smoke/smoke.mjs",
		"audit": "pnpm audit",
		"d2:svg": "node scripts/diagrams/render-d2.mjs svg",
		"d2:png": "node scripts/diagrams/render-d2.mjs png",
		"d2:pdf": "node scripts/diagrams/render-d2.mjs pdf",
		"docs:check": "pnpm docs:check:links && pnpm docs:check:index && pnpm docs:check:status",
		"docs:check:links": "node scripts/docs/check-links.mjs",
		"docs:check:index": "node scripts/docs/check-index.mjs",
		"docs:check:status": "node scripts/docs/check-status.mjs"
	},
	"devDependencies": {
		"@terrastruct/d2": "^0.1.33",
		"@typescript-eslint/eslint-plugin": "^8.60.0",
		"@typescript-eslint/parser": "^8.60.0",
		"dotenv-cli": "^11.0.0",
		"eslint": "^10.4.0",
		"eslint-plugin-boundaries": "^6.0.2",
		"react-doctor": "0.5.1",
		"turbo": "^2.8.1",
		"typescript": "^6.0.3"
	}
}
