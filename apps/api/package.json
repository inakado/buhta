{
	"name": "@buhta/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "dotenv -e ../../.env.example -e ../../.env -- tsx watch --exclude \"../../node_modules/**\" --exclude \"node_modules/**\" src/main.ts",
		"build": "prisma generate && tsc -p tsconfig.build.json",
		"start": "tsx src/main.ts",
		"lint": "eslint src test --ext .ts",
		"typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
		"test": "prisma generate && vitest run",
		"test:watch": "vitest",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:deploy": "prisma migrate deploy",
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@better-auth/prisma-adapter": "^1.6.11",
		"@buhta/shared": "workspace:*",
		"@nestjs/common": "^11.1.24",
		"@nestjs/core": "^11.1.24",
		"@nestjs/platform-express": "^11.1.24",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@thallesp/nestjs-better-auth": "^2.6.0",
		"better-auth": "^1.6.11",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.2",
		"helmet": "^8.2.0",
		"pg": "^8.21.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@nestjs/testing": "^11.1.24",
		"@types/cookie-parser": "^1.4.10",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.2.0",
		"prisma": "^7.8.0",
		"supertest": "^7.2.2",
		"tsx": "^4.22.3",
		"vitest": "^4.1.7"
	}
}
