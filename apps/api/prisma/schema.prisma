generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id
  name               String
  email              String              @unique
  emailVerified      Boolean             @default(false)
  image              String?
  username           String?             @unique
  displayUsername    String?
  role               String              @default("courier")
  banned             Boolean?            @default(false)
  banReason          String?
  banExpires         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  accounts           Account[]
  operations         Operation[]         @relation("OperationActor")
  auditLogs          AuditLog[]          @relation("AuditActor")
  idempotencyRecords IdempotencyRecord[] @relation("IdempotencyActor")

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Operation {
  id                 String              @id @default(cuid())
  type               String
  status             String              @default("succeeded")
  actorUserId        String
  idempotencyKey     String?
  metadata           Json?
  createdAt          DateTime            @default(now())
  actor              User                @relation("OperationActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  auditLogs          AuditLog[]
  idempotencyRecords IdempotencyRecord[]
  rawMaterialIntakes RawMaterialIntake[]
  packagingIntakes   PackagingIntake[]
  productBatches     ProductBatch[]
  productTransfers   ProductTransfer[]

  @@unique([actorUserId, idempotencyKey])
  @@index([actorUserId])
  @@map("operation")
}

model AuditLog {
  id          String    @id @default(cuid())
  operationId String
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  details     Json?
  createdAt   DateTime  @default(now())
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor       User      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([operationId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("audit_log")
}

model IdempotencyRecord {
  id               String    @id @default(cuid())
  key              String
  actorUserId      String
  commandName      String
  operationId      String
  requestHash      String
  responseHash     String?
  responseSnapshot Json?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  actor            User      @relation("IdempotencyActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  operation        Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@unique([actorUserId, key])
  @@index([operationId])
  @@index([expiresAt])
  @@map("idempotency_record")
}

model RawMaterialType {
  id               String            @id @default(cuid())
  name             String            @unique
  unit             String
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productTemplates ProductTemplate[]
  balance          RawMaterialBalance?
  intakes          RawMaterialIntake[]

  @@map("raw_material_type")
}

model PackagingType {
  id               String            @id @default(cuid())
  name             String            @unique
  unit             String
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productTemplates ProductTemplate[]
  balance          PackagingBalance?
  intakes          PackagingIntake[]

  @@map("packaging_type")
}

model Distributor {
  id               String                      @id @default(cuid())
  name             String                      @unique
  active           Boolean                     @default(true)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  productBalances  DistributorProductBalance[]
  productTransfers ProductTransfer[]

  @@map("distributor")
}

model ProductTemplate {
  id                String          @id @default(cuid())
  name              String          @unique
  rawMaterialTypeId String
  packagingTypeId   String
  priceCents        Int             @default(0)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  rawMaterialType   RawMaterialType @relation(fields: [rawMaterialTypeId], references: [id], onDelete: Restrict)
  packagingType     PackagingType   @relation(fields: [packagingTypeId], references: [id], onDelete: Restrict)
  productBatches    ProductBatch[]

  @@index([rawMaterialTypeId])
  @@index([packagingTypeId])
  @@map("product_template")
}

model RawMaterialBalance {
  id                String          @id @default(cuid())
  rawMaterialTypeId String          @unique
  quantity          Decimal         @default(0) @db.Decimal(12, 3)
  updatedAt         DateTime        @updatedAt
  rawMaterialType   RawMaterialType @relation(fields: [rawMaterialTypeId], references: [id], onDelete: Restrict)

  @@map("raw_material_balance")
}

model PackagingBalance {
  id              String        @id @default(cuid())
  packagingTypeId String        @unique
  quantity        Decimal       @default(0) @db.Decimal(12, 3)
  updatedAt       DateTime      @updatedAt
  packagingType   PackagingType @relation(fields: [packagingTypeId], references: [id], onDelete: Restrict)

  @@map("packaging_balance")
}

model RawMaterialIntake {
  id                String          @id @default(cuid())
  rawMaterialTypeId String
  quantity          Decimal         @db.Decimal(12, 3)
  comment           String?
  operationId       String          @unique
  actorUserId       String
  createdAt         DateTime        @default(now())
  rawMaterialType   RawMaterialType @relation(fields: [rawMaterialTypeId], references: [id], onDelete: Restrict)
  operation         Operation       @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([rawMaterialTypeId])
  @@index([actorUserId])
  @@map("raw_material_intake")
}

model PackagingIntake {
  id              String        @id @default(cuid())
  packagingTypeId String
  quantity        Decimal       @db.Decimal(12, 3)
  comment         String?
  operationId     String        @unique
  actorUserId     String
  createdAt       DateTime      @default(now())
  packagingType   PackagingType @relation(fields: [packagingTypeId], references: [id], onDelete: Restrict)
  operation       Operation     @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([packagingTypeId])
  @@index([actorUserId])
  @@map("packaging_intake")
}

model ProductBatch {
  id                          String          @id @default(cuid())
  productTemplateId           String
  productName                 String
  rawMaterialTypeId           String
  rawMaterialTypeName         String
  rawMaterialUnit             String
  packagingTypeId             String
  packagingTypeName           String
  packagingUnit               String
  priceCents                  Int
  quantity                    Int
  consumedRawMaterialQuantity Decimal         @db.Decimal(12, 3)
  consumedPackagingQuantity   Decimal         @db.Decimal(12, 3)
  status                      String          @default("in_workshop")
  operationId                 String          @unique
  actorUserId                 String
  createdAt                   DateTime        @default(now())
  productTemplate             ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Restrict)
  operation                   Operation       @relation(fields: [operationId], references: [id], onDelete: Restrict)
  workshopBalance             WorkshopProductBalance?
  distributorBalances         DistributorProductBalance[]
  transfers                   ProductTransfer[]

  @@index([productTemplateId])
  @@index([actorUserId])
  @@index([status])
  @@map("product_batch")
}

model WorkshopProductBalance {
  id             String       @id @default(cuid())
  productBatchId String       @unique
  quantity       Int
  updatedAt      DateTime     @updatedAt
  productBatch   ProductBatch @relation(fields: [productBatchId], references: [id], onDelete: Restrict)

  @@map("workshop_product_balance")
}

model DistributorProductBalance {
  id             String       @id @default(cuid())
  distributorId  String
  productBatchId String
  quantity       Int
  updatedAt      DateTime     @updatedAt
  distributor    Distributor  @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  productBatch   ProductBatch @relation(fields: [productBatchId], references: [id], onDelete: Restrict)

  @@unique([distributorId, productBatchId])
  @@index([distributorId])
  @@index([productBatchId])
  @@map("distributor_product_balance")
}

model ProductTransfer {
  id             String       @id @default(cuid())
  productBatchId String
  distributorId  String
  quantity       Int
  comment        String?
  operationId    String       @unique
  actorUserId    String
  createdAt      DateTime     @default(now())
  productBatch   ProductBatch @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  distributor    Distributor  @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  operation      Operation    @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([productBatchId])
  @@index([distributorId])
  @@index([actorUserId])
  @@map("product_transfer")
}
