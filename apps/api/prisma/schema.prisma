generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String                  @id
  name               String
  email              String                  @unique
  emailVerified      Boolean                 @default(false)
  image              String?
  username           String?                 @unique
  displayUsername    String?
  role               String                  @default("courier")
  banned             Boolean?                @default(false)
  banReason          String?
  banExpires         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  sessions           Session[]
  accounts           Account[]
  operations         Operation[]             @relation("OperationActor")
  auditLogs          AuditLog[]              @relation("AuditActor")
  idempotencyRecords IdempotencyRecord[]     @relation("IdempotencyActor")
  createdClients     Client[]                @relation("ClientCreatedBy")
  courierBalances    CourierProductBalance[] @relation("CourierProductBalanceCourier")
  courierCashBalance CourierCashBalance?     @relation("CourierCashBalanceCourier")
  courierLoads       CourierLoad[]           @relation("CourierLoadCourier")
  courierSales       CourierSale[]           @relation("CourierSaleCourier")
  cancelledCourierSales CourierSaleCancellation[] @relation("CourierSaleCancellationCourier")
  courierSaleCancellations CourierSaleCancellation[] @relation("CourierSaleCancellationActor")
  courierUnloads     CourierUnload[]         @relation("CourierUnloadCourier")
  distributorCashWithdrawals DistributorCashWithdrawal[] @relation("DistributorCashWithdrawalActor")
  distributorSaleCancellations DistributorSaleCancellation[] @relation("DistributorSaleCancellationActor")
  productDiscountAssignments ProductDiscountAssignment[] @relation("ProductDiscountAssignmentActor")
  createdProductionNotifications   ProductionNotification[] @relation("ProductionNotificationCreatedBy")
  completedProductionNotifications ProductionNotification[] @relation("ProductionNotificationCompletedBy")

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Operation {
  id                 String              @id @default(cuid())
  type               String
  status             String              @default("succeeded")
  actorUserId        String
  idempotencyKey     String?
  metadata           Json?
  createdAt          DateTime            @default(now())
  actor              User                @relation("OperationActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  auditLogs          AuditLog[]
  idempotencyRecords IdempotencyRecord[]
  rawMaterialIntakes RawMaterialIntake[]
  packagingIntakes   PackagingIntake[]
  productBatches     ProductBatch[]
  productTransfers   ProductTransfer[]
  distributorSales   DistributorSale[]
  distributorSaleCancellations DistributorSaleCancellation[]
  distributorCashWithdrawals DistributorCashWithdrawal[]
  productDiscountAssignments ProductDiscountAssignment[]
  courierLoads       CourierLoad[]
  courierSales       CourierSale[]
  courierSaleCancellations CourierSaleCancellation[]
  courierUnloads     CourierUnload[]
  productionNotificationCreates   ProductionNotification[] @relation("ProductionNotificationCreateOperation")
  productionNotificationCompletes ProductionNotification[] @relation("ProductionNotificationCompleteOperation")

  @@unique([actorUserId, idempotencyKey])
  @@index([actorUserId])
  @@index([type, createdAt], map: "operation_type_createdAt_idx")
  @@map("operation")
}

model AuditLog {
  id          String    @id @default(cuid())
  operationId String
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  details     Json?
  createdAt   DateTime  @default(now())
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor       User      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([operationId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt, id], map: "audit_log_createdAt_id_idx")
  @@index([action, createdAt], map: "audit_log_action_createdAt_idx")
  @@index([actorUserId, createdAt, id], map: "audit_log_actorUserId_createdAt_id_idx")
  @@index([entityType, createdAt, id], map: "audit_log_entityType_createdAt_id_idx")
  @@map("audit_log")
}

model IdempotencyRecord {
  id               String    @id @default(cuid())
  key              String
  actorUserId      String
  commandName      String
  operationId      String
  requestHash      String
  responseHash     String?
  responseSnapshot Json?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  actor            User      @relation("IdempotencyActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  operation        Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@unique([actorUserId, key])
  @@index([operationId])
  @@index([expiresAt])
  @@map("idempotency_record")
}

model RawMaterialType {
  id               String              @id @default(cuid())
  name             String              @unique
  unit             String
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  productTemplates ProductTemplate[]
  balance          RawMaterialBalance?
  intakes          RawMaterialIntake[]

  @@map("raw_material_type")
}

model PackagingType {
  id               String            @id @default(cuid())
  name             String            @unique
  unit             String
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productTemplates ProductTemplate[]
  balance          PackagingBalance?
  intakes          PackagingIntake[]

  @@map("packaging_type")
}

model Distributor {
  id               String                      @id @default(cuid())
  name             String                      @unique
  active           Boolean                     @default(true)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  productBalances  DistributorProductBalance[]
  productTransfers ProductTransfer[]
  cashBalance      DistributorCashBalance?
  sales            DistributorSale[]
  saleCancellations DistributorSaleCancellation[]
  cashWithdrawals  DistributorCashWithdrawal[]
  productDiscountAssignments ProductDiscountAssignment[]
  courierLoads     CourierLoad[]
  courierUnloads   CourierUnload[]

  @@map("distributor")
}

model Client {
  id               String            @id @default(cuid())
  name             String
  phone            String
  phoneNormalized  String            @unique
  description      String?
  createdByUserId  String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        User              @relation("ClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  distributorSales DistributorSale[]
  distributorSaleCancellations DistributorSaleCancellation[]
  courierSales     CourierSale[]
  courierSaleCancellations CourierSaleCancellation[]

  @@index([name])
  @@index([createdByUserId])
  @@map("client")
}

model ProductTemplate {
  id                String          @id @default(cuid())
  name              String          @unique
  rawMaterialTypeId String
  packagingTypeId   String
  priceCents        Int             @default(0)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  rawMaterialType   RawMaterialType @relation(fields: [rawMaterialTypeId], references: [id], onDelete: Restrict)
  packagingType     PackagingType   @relation(fields: [packagingTypeId], references: [id], onDelete: Restrict)
  productBatches    ProductBatch[]

  @@index([rawMaterialTypeId])
  @@index([packagingTypeId])
  @@map("product_template")
}

model RawMaterialBalance {
  id                String          @id @default(cuid())
  rawMaterialTypeId String          @unique
  quantity          Decimal         @default(0) @db.Decimal(12, 3)
  updatedAt         DateTime        @updatedAt
  rawMaterialType   RawMaterialType @relation(fields: [rawMaterialTypeId], references: [id], onDelete: Restrict)

  @@map("raw_material_balance")
}

model PackagingBalance {
  id              String        @id @default(cuid())
  packagingTypeId String        @unique
  quantity        Decimal       @default(0) @db.Decimal(12, 3)
  updatedAt       DateTime      @updatedAt
  packagingType   PackagingType @relation(fields: [packagingTypeId], references: [id], onDelete: Restrict)

  @@map("packaging_balance")
}

model RawMaterialIntake {
  id                String          @id @default(cuid())
  rawMaterialTypeId String
  quantity          Decimal         @db.Decimal(12, 3)
  comment           String?
  operationId       String          @unique
  actorUserId       String
  createdAt         DateTime        @default(now())
  rawMaterialType   RawMaterialType @relation(fields: [rawMaterialTypeId], references: [id], onDelete: Restrict)
  operation         Operation       @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([rawMaterialTypeId])
  @@index([actorUserId])
  @@map("raw_material_intake")
}

model PackagingIntake {
  id              String        @id @default(cuid())
  packagingTypeId String
  quantity        Decimal       @db.Decimal(12, 3)
  comment         String?
  operationId     String        @unique
  actorUserId     String
  createdAt       DateTime      @default(now())
  packagingType   PackagingType @relation(fields: [packagingTypeId], references: [id], onDelete: Restrict)
  operation       Operation     @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([packagingTypeId])
  @@index([actorUserId])
  @@map("packaging_intake")
}

model ProductBatch {
  id                          String                      @id @default(cuid())
  productTemplateId           String
  productName                 String
  rawMaterialTypeId           String
  rawMaterialTypeName         String
  rawMaterialUnit             String
  packagingTypeId             String
  packagingTypeName           String
  packagingUnit               String
  priceCents                  Int
  quantity                    Int
  consumedRawMaterialQuantity Decimal                     @db.Decimal(12, 3)
  consumedPackagingQuantity   Decimal                     @db.Decimal(12, 3)
  status                      String                      @default("in_workshop")
  operationId                 String                      @unique
  actorUserId                 String
  createdAt                   DateTime                    @default(now())
  productTemplate             ProductTemplate             @relation(fields: [productTemplateId], references: [id], onDelete: Restrict)
  operation                   Operation                   @relation(fields: [operationId], references: [id], onDelete: Restrict)
  workshopBalance             WorkshopProductBalance?
  distributorBalances         DistributorProductBalance[]
  transfers                   ProductTransfer[]
  distributorSales            DistributorSale[]
  distributorSaleCancellations DistributorSaleCancellation[]
  courierBalances             CourierProductBalance[]
  courierLoads                CourierLoad[]
  courierSales                CourierSale[]
  courierSaleCancellations    CourierSaleCancellation[]
  courierUnloadItems          CourierUnloadItem[]
  productDiscountAssignments  ProductDiscountAssignment[]

  @@index([productTemplateId])
  @@index([actorUserId])
  @@index([status])
  @@map("product_batch")
}

model WorkshopProductBalance {
  id             String       @id @default(cuid())
  productBatchId String       @unique
  quantity       Int
  updatedAt      DateTime     @updatedAt
  productBatch   ProductBatch @relation(fields: [productBatchId], references: [id], onDelete: Restrict)

  @@map("workshop_product_balance")
}

model DistributorProductBalance {
  id             String            @id @default(cuid())
  distributorId  String
  productBatchId String
  unitPriceCents Int
  quantity       Int
  updatedAt      DateTime          @updatedAt
  distributor    Distributor       @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  productBatch   ProductBatch      @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  sales          DistributorSale[]
  saleCancellations DistributorSaleCancellation[]
  courierLoads   CourierLoad[]
  unloadItems    CourierUnloadItem[]
  sourceDiscountAssignments ProductDiscountAssignment[] @relation("ProductDiscountSourceBalance")
  discountedDiscountAssignments ProductDiscountAssignment[] @relation("ProductDiscountDiscountedBalance")

  @@unique([distributorId, productBatchId, unitPriceCents])
  @@index([distributorId])
  @@index([productBatchId])
  @@map("distributor_product_balance")
}

model ProductTransfer {
  id             String       @id @default(cuid())
  productBatchId String
  distributorId  String
  quantity       Int
  baseUnitPriceCents Int
  unitPriceCents Int
  discountCentsPerUnit Int
  stockValueCents Int
  comment        String?
  operationId    String       @unique
  actorUserId    String
  createdAt      DateTime     @default(now())
  productBatch   ProductBatch @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  distributor    Distributor  @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  operation      Operation    @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([productBatchId])
  @@index([distributorId])
  @@index([actorUserId])
  @@map("product_transfer")
}

model DistributorCashBalance {
  id            String      @id @default(cuid())
  distributorId String      @unique
  amountCents   Int         @default(0)
  updatedAt     DateTime    @updatedAt
  distributor   Distributor @relation(fields: [distributorId], references: [id], onDelete: Restrict)

  @@map("distributor_cash_balance")
}

model DistributorCashWithdrawal {
  id            String      @id @default(cuid())
  distributorId String
  amountCents   Int
  comment       String?
  operationId   String      @unique
  actorUserId   String
  createdAt     DateTime    @default(now())
  distributor   Distributor @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  operation     Operation   @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor         User        @relation("DistributorCashWithdrawalActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([distributorId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("distributor_cash_withdrawal")
}

model DistributorSale {
  id                          String                    @id @default(cuid())
  distributorProductBalanceId String
  distributorId               String
  productBatchId              String
  clientId                    String
  quantity                    Int
  baseUnitPriceCents          Int
  unitPriceCents              Int
  discountCentsPerUnit        Int             @default(0)
  discountTotalCents          Int             @default(0)
  totalCents                  Int
  paymentMethod               String
  comment                     String?
  operationId                 String                    @unique
  actorUserId                 String
  createdAt                   DateTime                  @default(now())
  distributorProductBalance   DistributorProductBalance @relation(fields: [distributorProductBalanceId], references: [id], onDelete: Restrict)
  distributor                 Distributor               @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  productBatch                ProductBatch              @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  client                      Client                    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  operation                   Operation                 @relation(fields: [operationId], references: [id], onDelete: Restrict)
  cancellation                DistributorSaleCancellation?

  @@index([distributorId])
  @@index([productBatchId])
  @@index([clientId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("distributor_sale")
}

model DistributorSaleCancellation {
  id                          String                    @id @default(cuid())
  distributorSaleId           String                    @unique
  distributorProductBalanceId String
  distributorId               String
  productBatchId              String
  clientId                    String
  quantity                    Int
  baseUnitPriceCents          Int
  unitPriceCents              Int
  discountCentsPerUnit        Int                       @default(0)
  discountTotalCents          Int                       @default(0)
  totalCents                  Int
  paymentMethod               String
  reason                      String
  operationId                 String                    @unique
  actorUserId                 String
  createdAt                   DateTime                  @default(now())
  distributorSale             DistributorSale           @relation(fields: [distributorSaleId], references: [id], onDelete: Restrict)
  distributorProductBalance   DistributorProductBalance @relation(fields: [distributorProductBalanceId], references: [id], onDelete: Restrict)
  distributor                 Distributor               @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  productBatch                ProductBatch              @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  client                      Client                    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  operation                   Operation                 @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor                       User                      @relation("DistributorSaleCancellationActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([distributorProductBalanceId])
  @@index([distributorId])
  @@index([productBatchId])
  @@index([clientId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("distributor_sale_cancellation")
}

model CourierProductBalance {
  id             String        @id @default(cuid())
  courierUserId  String
  productBatchId String
  unitPriceCents Int
  quantity       Int
  updatedAt      DateTime      @updatedAt
  courier        User          @relation("CourierProductBalanceCourier", fields: [courierUserId], references: [id], onDelete: Restrict)
  productBatch   ProductBatch  @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  sales          CourierSale[]
  saleCancellations CourierSaleCancellation[]
  unloadItems    CourierUnloadItem[]

  @@unique([courierUserId, productBatchId, unitPriceCents])
  @@index([courierUserId])
  @@index([productBatchId])
  @@map("courier_product_balance")
}

model CourierCashBalance {
  id            String   @id @default(cuid())
  courierUserId String   @unique
  amountCents   Int      @default(0)
  updatedAt     DateTime @updatedAt
  courier       User     @relation("CourierCashBalanceCourier", fields: [courierUserId], references: [id], onDelete: Restrict)

  @@map("courier_cash_balance")
}

model CourierLoad {
  id                          String                    @id @default(cuid())
  courierUserId               String
  distributorProductBalanceId String
  distributorId               String
  productBatchId              String
  quantity                    Int
  baseUnitPriceCents          Int
  unitPriceCents              Int
  discountCentsPerUnit        Int
  stockValueCents             Int
  comment                     String?
  operationId                 String                    @unique
  actorUserId                 String
  createdAt                   DateTime                  @default(now())
  courier                     User                      @relation("CourierLoadCourier", fields: [courierUserId], references: [id], onDelete: Restrict)
  distributorProductBalance   DistributorProductBalance @relation(fields: [distributorProductBalanceId], references: [id], onDelete: Restrict)
  distributor                 Distributor               @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  productBatch                ProductBatch              @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  operation                   Operation                 @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@index([courierUserId])
  @@index([distributorId])
  @@index([productBatchId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("courier_load")
}

model CourierSale {
  id                      String                @id @default(cuid())
  courierProductBalanceId String
  courierUserId           String
  productBatchId          String
  clientId                String
  quantity                Int
  baseUnitPriceCents      Int
  unitPriceCents          Int
  discountCentsPerUnit    Int      @default(0)
  discountTotalCents      Int      @default(0)
  totalCents              Int
  paymentMethod           String
  comment                 String?
  operationId             String                @unique
  actorUserId             String
  createdAt               DateTime              @default(now())
  courierProductBalance   CourierProductBalance @relation(fields: [courierProductBalanceId], references: [id], onDelete: Restrict)
  courier                 User                  @relation("CourierSaleCourier", fields: [courierUserId], references: [id], onDelete: Restrict)
  productBatch            ProductBatch          @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  client                  Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  operation               Operation             @relation(fields: [operationId], references: [id], onDelete: Restrict)
  cancellation            CourierSaleCancellation?

  @@index([courierProductBalanceId])
  @@index([courierUserId])
  @@index([productBatchId])
  @@index([clientId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("courier_sale")
}

model CourierSaleCancellation {
  id                      String                @id @default(cuid())
  courierSaleId           String                @unique
  courierProductBalanceId String
  courierUserId           String
  productBatchId          String
  clientId                String
  quantity                Int
  baseUnitPriceCents      Int
  unitPriceCents          Int
  discountCentsPerUnit    Int                   @default(0)
  discountTotalCents      Int                   @default(0)
  totalCents              Int
  paymentMethod           String
  reason                  String
  operationId             String                @unique
  actorUserId             String
  createdAt               DateTime              @default(now())
  courierSale             CourierSale           @relation(fields: [courierSaleId], references: [id], onDelete: Restrict)
  courierProductBalance   CourierProductBalance @relation(fields: [courierProductBalanceId], references: [id], onDelete: Restrict)
  courier                 User                  @relation("CourierSaleCancellationCourier", fields: [courierUserId], references: [id], onDelete: Restrict)
  productBatch            ProductBatch          @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  client                  Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  operation               Operation             @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor                   User                  @relation("CourierSaleCancellationActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([courierProductBalanceId])
  @@index([courierUserId])
  @@index([productBatchId])
  @@index([clientId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("courier_sale_cancellation")
}

model CourierUnload {
  id              String              @id @default(cuid())
  courierUserId   String
  distributorId   String
  cashAmountCents Int                 @default(0)
  comment         String?
  operationId     String              @unique
  actorUserId     String
  createdAt       DateTime            @default(now())
  courier         User                @relation("CourierUnloadCourier", fields: [courierUserId], references: [id], onDelete: Restrict)
  distributor     Distributor         @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  operation       Operation           @relation(fields: [operationId], references: [id], onDelete: Restrict)
  items           CourierUnloadItem[]

  @@index([courierUserId])
  @@index([distributorId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("courier_unload")
}

model CourierUnloadItem {
  id                          String                   @id @default(cuid())
  courierUnloadId             String
  courierProductBalanceId     String
  distributorProductBalanceId String
  productBatchId              String
  quantity                    Int
  baseUnitPriceCents          Int
  unitPriceCents              Int
  discountCentsPerUnit        Int
  stockValueCents             Int
  courierUnload               CourierUnload            @relation(fields: [courierUnloadId], references: [id], onDelete: Restrict)
  courierProductBalance       CourierProductBalance     @relation(fields: [courierProductBalanceId], references: [id], onDelete: Restrict)
  distributorProductBalance   DistributorProductBalance @relation(fields: [distributorProductBalanceId], references: [id], onDelete: Restrict)
  productBatch                ProductBatch              @relation(fields: [productBatchId], references: [id], onDelete: Restrict)

  @@unique([courierUnloadId, courierProductBalanceId])
  @@index([courierProductBalanceId])
  @@index([distributorProductBalanceId])
  @@index([productBatchId])
  @@map("courier_unload_item")
}

model ProductDiscountAssignment {
  id                                    String                    @id @default(cuid())
  sourceDistributorProductBalanceId     String
  discountedDistributorProductBalanceId String
  distributorId                         String
  productBatchId                        String
  quantity                              Int
  baseUnitPriceCents                    Int
  sourceUnitPriceCents                  Int
  discountedUnitPriceCents              Int
  discountCentsPerUnit                  Int
  stepDiscountCentsPerUnit              Int
  discountTotalCents                    Int
  comment                               String?
  operationId                           String                    @unique
  actorUserId                           String
  createdAt                             DateTime                  @default(now())
  sourceDistributorProductBalance       DistributorProductBalance @relation("ProductDiscountSourceBalance", fields: [sourceDistributorProductBalanceId], references: [id], onDelete: Restrict)
  discountedDistributorProductBalance   DistributorProductBalance @relation("ProductDiscountDiscountedBalance", fields: [discountedDistributorProductBalanceId], references: [id], onDelete: Restrict)
  distributor                           Distributor               @relation(fields: [distributorId], references: [id], onDelete: Restrict)
  productBatch                          ProductBatch              @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  operation                             Operation                 @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor                                 User                      @relation("ProductDiscountAssignmentActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([sourceDistributorProductBalanceId])
  @@index([discountedDistributorProductBalanceId])
  @@index([distributorId])
  @@index([productBatchId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("product_discount_assignment")
}

model ProductionNotification {
  id                  String     @id @default(cuid())
  message             String
  status              String     @default("new")
  createdByUserId     String
  completedByUserId   String?
  createOperationId   String     @unique
  completeOperationId String?    @unique
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  completedAt         DateTime?
  createdBy           User       @relation("ProductionNotificationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  completedBy         User?      @relation("ProductionNotificationCompletedBy", fields: [completedByUserId], references: [id], onDelete: Restrict)
  createOperation     Operation  @relation("ProductionNotificationCreateOperation", fields: [createOperationId], references: [id], onDelete: Restrict)
  completeOperation   Operation? @relation("ProductionNotificationCompleteOperation", fields: [completeOperationId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([createdByUserId])
  @@index([completedByUserId])
  @@index([createdAt])
  @@index([completedAt])
  @@map("production_notification")
}
