generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id
  name               String
  email              String              @unique
  emailVerified      Boolean             @default(false)
  image              String?
  username           String?             @unique
  displayUsername    String?
  role               String              @default("courier")
  banned             Boolean?            @default(false)
  banReason          String?
  banExpires         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  accounts           Account[]
  operations         Operation[]         @relation("OperationActor")
  auditLogs          AuditLog[]          @relation("AuditActor")
  idempotencyRecords IdempotencyRecord[] @relation("IdempotencyActor")

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Operation {
  id                 String              @id @default(cuid())
  type               String
  status             String              @default("succeeded")
  actorUserId        String
  idempotencyKey     String?
  metadata           Json?
  createdAt          DateTime            @default(now())
  actor              User                @relation("OperationActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  auditLogs          AuditLog[]
  idempotencyRecords IdempotencyRecord[]

  @@unique([actorUserId, idempotencyKey])
  @@index([actorUserId])
  @@map("operation")
}

model AuditLog {
  id          String    @id @default(cuid())
  operationId String
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  details     Json?
  createdAt   DateTime  @default(now())
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)
  actor       User      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([operationId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("audit_log")
}

model IdempotencyRecord {
  id               String    @id @default(cuid())
  key              String
  actorUserId      String
  commandName      String
  operationId      String
  requestHash      String
  responseHash     String?
  responseSnapshot Json?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  actor            User      @relation("IdempotencyActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  operation        Operation @relation(fields: [operationId], references: [id], onDelete: Restrict)

  @@unique([actorUserId, key])
  @@index([operationId])
  @@index([expiresAt])
  @@map("idempotency_record")
}
